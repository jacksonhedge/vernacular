# Vernacular — Environment Variables
# Copy to .env.local and fill in actual values

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Notion (required for message sync and contacts)
NOTION_TOKEN=ntn_your-notion-token
NOTION_MESSAGE_LOG_DB=your-notion-message-log-database-id

# Admin (optional — has a default fallback)
ADMIN_PASSWORD=your-admin-password

# Station runner (set on each Mac station)
# STATION_ID=your-station-uuid
# SUPABASE_SERVICE_KEY=your-service-role-key
