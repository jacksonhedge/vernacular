{
  "name": "@vernacular/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Vernacular iMessage CRM API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "vernacular",
    "imessage",
    "crm",
    "sms",
    "messaging"
  ],
  "author": "Hedge, Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jacksonhedge/vernacular"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
